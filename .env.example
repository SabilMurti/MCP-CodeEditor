# Configuration for MCP Code Editor (Tukang Ketik)

# The API URL for chat completions (e.g., CometAPI, OpenRouter, DeepSeek, or local Ollama)
# Default is CometAPI chat completions URL
CODER_API_URL=https://api.cometapi.com/v1/chat/completions

# Your API Key for the chosen provider
CODER_API_KEY=your_api_key_here

# The model name to use for writing code (e.g., gemini-1.5-flash, deepseek-coder, llama-3, etc.)
CODER_MODEL=gemini-1.5-flash
